<mxfile>
  <diagram name="SRE Agent Demo Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Azure Cloud boundary -->
        <mxCell id="cloud" value="Azure Cloud" style="rounded=1;dashed=1;dashPattern=5 5;strokeColor=#0078D4;fillColor=#F0F8FF;verticalAlign=top;fontSize=14;fontStyle=1;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1760" height="1010" as="geometry"/>
        </mxCell>

        <!-- Resource Group boundary -->
        <mxCell id="rg" value="Resource Group: sreagent-&lt;suffix&gt;" style="rounded=1;dashed=1;dashPattern=3 3;strokeColor=#505050;fillColor=#FAFAFA;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1720" height="950" as="geometry"/>
        </mxCell>

        <!-- ============ LEFT COLUMN: AKS CLUSTER ============ -->
        <mxCell id="aksgrp" value="AKS Cluster (3 nodes, D2s_v5)" style="rounded=1;dashed=1;dashPattern=5 5;strokeColor=#326CE5;fillColor=#E8F0FE;verticalAlign=top;fontSize=11;fontStyle=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="500" height="450" as="geometry"/>
        </mxCell>

        <mxCell id="aks" value="" style="shape=mxgraph.azure2.compute.kubernetes_services;fillColor=#0078D4;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="80" y="115" width="35" height="35" as="geometry"/>
        </mxCell>

        <!-- Namespace -->
        <mxCell id="ns" value="namespace: aks-journal-app" style="rounded=1;dashed=1;dashPattern=2 2;strokeColor=#326CE5;fillColor=#E3F2FD;verticalAlign=top;fontSize=10;fontStyle=2;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="80" y="165" width="460" height="200" as="geometry"/>
        </mxCell>

        <!-- Pods -->
        <mxCell id="pod1" value="Pod 1&#xa;aks-journal" style="rounded=1;whiteSpace=wrap;fillColor=#326CE5;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pod2" value="Pod 2&#xa;aks-journal" style="rounded=1;whiteSpace=wrap;fillColor=#326CE5;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="200" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pod3" value="Pod 3&#xa;aks-journal" style="rounded=1;whiteSpace=wrap;fillColor=#326CE5;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="200" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Service -->
        <mxCell id="svc" value="Service (LoadBalancer)&#xa;:80 → :3000" style="rounded=1;whiteSpace=wrap;fillColor=#E8F5E9;strokeColor=#4CAF50;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- HPA + PDB -->
        <mxCell id="hpa" value="HPA (3-10 replicas)&#xa;CPU 70% / Mem 80%" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="260" y="280" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="pdb" value="PDB&#xa;minAvailable: 2" style="rounded=1;whiteSpace=wrap;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="410" y="280" width="110" height="40" as="geometry"/>
        </mxCell>

        <!-- Probes -->
        <mxCell id="probes" value="Probes: /live  /ready  /health" style="rounded=1;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#9C27B0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="260" y="335" width="260" height="25" as="geometry"/>
        </mxCell>

        <!-- Container Insights + Diagnostics -->
        <mxCell id="insights" value="Container Insights" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="diag" value="Diagnostics (apiserver, audit, autoscaler)" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="400" width="230" height="35" as="geometry"/>
        </mxCell>

        <!-- ACR below AKS -->
        <mxCell id="acr" value="" style="shape=mxgraph.azure2.compute.container_registries;fillColor=#0078D4;" vertex="1" parent="1">
          <mxGeometry x="500" y="400" width="35" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="acrlbl" value="ACR" style="text;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="498" y="438" width="40" height="15" as="geometry"/>
        </mxCell>

        <!-- ============ MIDDLE-LEFT: REDIS ============ -->
        <mxCell id="redis" value="" style="shape=mxgraph.azure2.databases.cache_redis;fillColor=#0078D4;" vertex="1" parent="1">
          <mxGeometry x="640" y="200" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="redislbl" value="Azure Cache for Redis&#xa;(Basic C0, TLS)" style="text;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="610" y="255" width="110" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow: Pods to Redis (straight right, no overlap) -->
        <mxCell id="e1" value="" style="edgeStyle=entityRelationEdgeStyle;strokeColor=#0078D4;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;curved=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="225" as="sourcePoint"/>
            <mxPoint x="640" y="225" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ============ MIDDLE: LOG ANALYTICS ============ -->
        <mxCell id="law" value="" style="shape=mxgraph.azure2.management_governance.log_analytics_workspaces;fillColor=#0078D4;" vertex="1" parent="1">
          <mxGeometry x="640" y="390" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lawlbl" value="Log Analytics&#xa;Workspace" style="text;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="615" y="445" width="100" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow: Insights to LAW (straight right) -->
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="insights" target="law" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2b" value="" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1565C0;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="diag" target="law" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============ RIGHT-MIDDLE: AZURE MONITOR ============ -->
        <mxCell id="mongrp" value="Azure Monitor" style="rounded=1;dashed=1;dashPattern=5 5;strokeColor=#FF6F00;fillColor=#FFF8E1;verticalAlign=top;fontSize=12;fontStyle=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="340" height="400" as="geometry"/>
        </mxCell>

        <mxCell id="alerts" value="Alert Rules (11 total)" style="rounded=1;whiteSpace=wrap;fillColor=#FF6F00;fontColor=#FFFFFF;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="145" width="280" height="28" as="geometry"/>
        </mxCell>

        <!-- Metric alerts column -->
        <mxCell id="metlbl" value="Metric Alerts" style="text;fontSize=9;fontStyle=3;align=center;fontColor=#FF6F00;" vertex="1" parent="1">
          <mxGeometry x="810" y="180" width="120" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="a1" value="High CPU (&gt;80%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="200" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a2" value="High Memory (&gt;80%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="230" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a3" value="Pod Restarts" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#FF9800;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="260" width="120" height="25" as="geometry"/>
        </mxCell>

        <!-- Log-based alerts column -->
        <mxCell id="loglbl" value="Log-based Alerts" style="text;fontSize=9;fontStyle=3;align=center;fontColor=#F44336;" vertex="1" parent="1">
          <mxGeometry x="950" y="180" width="140" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="a4" value="OOMKilled" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="200" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a5" value="Container Errors" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="230" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a6" value="Redis Conn Errors" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="260" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a7" value="Probe Failures" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="290" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a8" value="CrashLoop BackOff" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="950" y="320" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a9" value="Job Failures" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="290" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a10" value="Pods Not Ready" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="320" width="120" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="a11" value="Ingress Timeouts" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#F44336;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="810" y="350" width="120" height="25" as="geometry"/>
        </mxCell>

        <!-- Action Group -->
        <mxCell id="ag" value="Action Group (Webhook → SRE Agent)" style="rounded=1;whiteSpace=wrap;fillColor=#FF6F00;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="400" width="280" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrow: LAW to Monitor (straight right, enters left side) -->
        <mxCell id="e3" value="telemetry" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#FF6F00;strokeWidth=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="law" target="mongrp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============ FAR RIGHT: SRE AGENT ============ -->
        <mxCell id="sregrp" value="" style="rounded=1;strokeColor=#7B1FA2;fillColor=#F3E5F5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1200" y="100" width="310" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="srelbl" value="Azure SRE Agent" style="text;fontSize=14;fontStyle=1;fillColor=none;align=center;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="1260" y="110" width="190" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="sreurl" value="sre.azure.com" style="text;fontSize=9;fontStyle=2;align=center;fontColor=#9C27B0;" vertex="1" parent="1">
          <mxGeometry x="1300" y="133" width="110" height="15" as="geometry"/>
        </mxCell>

        <mxCell id="sre1" value="🔍 Investigate&#xa;  Log Analytics queries&#xa;  kubectl diagnostics&#xa;  Azure Resource Graph" style="rounded=1;whiteSpace=wrap;fillColor=#EDE7F6;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="155" width="270" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="sre2" value="🔧 Diagnose&#xa;  Root cause analysis&#xa;  CPU starvation vs OOMKill&#xa;  Credential mismatch detection" style="rounded=1;whiteSpace=wrap;fillColor=#EDE7F6;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="230" width="270" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="sre3" value="🛠️ Remediate&#xa;  Patch deployments&#xa;  Scale resources&#xa;  Verify recovery" style="rounded=1;whiteSpace=wrap;fillColor=#EDE7F6;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="305" width="270" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="sre4" value="📋 Follow-up&#xa;  GitHub issues + PRs&#xa;  Teams notifications&#xa;  Jira / ServiceNow tickets" style="rounded=1;whiteSpace=wrap;fillColor=#EDE7F6;strokeColor=#7B1FA2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1220" y="375" width="270" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: Action Group to SRE Agent (straight right, no overlap) -->
        <mxCell id="e4" value="webhook" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B1FA2;strokeWidth=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ag" target="sre1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: SRE Agent remediate back to AKS (routes below everything) -->
        <mxCell id="e5" value="kubectl / Azure CLI" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B1FA2;strokeWidth=2;dashed=1;fontSize=9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="sregrp" target="aksgrp" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1355" y="570"/>
              <mxPoint x="310" y="570"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ BOTTOM LEFT: FAULT INJECTION ============ -->
        <mxCell id="faults" value="🎯 Fault Injection Scenarios" style="rounded=1;strokeColor=#D32F2F;fillColor=#FFEBEE;verticalAlign=top;fontSize=11;fontStyle=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="660" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="f1" value="1️⃣ Redis Credential Expiry&#xa;Wrong password → degraded state → 500 errors" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#D32F2F;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="660" width="290" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="2️⃣ CPU Starvation&#xa;5m CPU limit → startup timeout → exit code 1" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#D32F2F;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="400" y="660" width="290" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="3️⃣ OOM Kill&#xa;20Mi memory limit → instant kill → exit code 137" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#D32F2F;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="720" width="290" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="f4" value="4️⃣ CrashLoop&#xa;Bad entrypoint → immediate exit → BackOff events" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#D32F2F;fontSize=9;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="400" y="720" width="290" height="45" as="geometry"/>
        </mxCell>

        <!-- ============ BOTTOM RIGHT: CONNECTORS ============ -->
        <mxCell id="conngrp" value="Connectors" style="rounded=1;strokeColor=#1565C0;fillColor=#E3F2FD;verticalAlign=top;fontSize=11;fontStyle=1;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="780" y="620" width="730" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="gh" value="GitHub&#xa;Issues + PRs" style="rounded=1;whiteSpace=wrap;fillColor=#24292E;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="670" width="130" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="teams" value="Microsoft&#xa;Teams" style="rounded=1;whiteSpace=wrap;fillColor=#505AC9;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="670" width="130" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="jira" value="Jira / ServiceNow&#xa;Tickets" style="rounded=1;whiteSpace=wrap;fillColor=#0052CC;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1140" y="670" width="130" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pager" value="PagerDuty&#xa;Incidents" style="rounded=1;whiteSpace=wrap;fillColor=#06AC38;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1300" y="670" width="130" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow: SRE follow-up to connectors (goes down from SRE group, enters connectors from top) -->
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B1FA2;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="sre4" target="conngrp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Permission/Mode labels -->
        <mxCell id="modes" value="Permission Levels: Reader → Privileged  |  Run Modes: Review (approval-gated) → Autonomous" style="text;fontSize=10;fontStyle=2;align=center;fillColor=none;fontColor=#505050;" vertex="1" parent="1">
          <mxGeometry x="780" y="740" width="730" height="20" as="geometry"/>
        </mxCell>

        <!-- Cost label -->
        <mxCell id="cost" value="Estimated Cost: ~$8.40/day" style="text;fontSize=11;fontStyle=1;align=center;fillColor=#E8F5E9;strokeColor=#4CAF50;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="830" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- Flow arrows legend -->
        <mxCell id="legend" value="Data flow: AKS → Log Analytics → Azure Monitor → Action Group → SRE Agent → Remediate AKS" style="text;fontSize=10;fontStyle=2;align=center;fillColor=none;fontColor=#0078D4;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="660" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
